{{!--
  Partial: social-icons
  ---------------------
  Renders social icon links from the site owner's Ghost profile.
  Icons appear automatically for any network the owner has filled in.
  Requires the following icon partials to exist in partials/icons/:
    facebook, twitter, instagram, linkedin, youtube,
    threads, bluesky, mastodon, tiktok, rss

  Usage:
    {{> "components/social-icons"}}

  Optional wrapper class override (defaults to "gh-footer-social"):
    {{> "components/social-icons" wrapperClass="my-social-bar"}}
--}}
{{#get "authors" limit="1" as |owners|}}
{{#foreach owners}}
<div class="{{#if wrapperClass}}{{wrapperClass}}{{else}}gh-footer-social{{/if}}" aria-label="Social links">
    {{#if facebook}}
    <a class="gh-social-link" href="{{social_url type="facebook"}}" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
        {{> "icons/facebook"}}
    </a>
    {{/if}}
    {{#if twitter}}
    <a class="gh-social-link" href="{{social_url type="twitter"}}" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)">
        {{> "icons/twitter"}}
    </a>
    {{/if}}
    {{#if instagram}}
    <a class="gh-social-link" href="{{social_url type="instagram"}}" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
        {{> "icons/instagram"}}
    </a>
    {{/if}}
    {{#if linkedin}}
    <a class="gh-social-link" href="{{social_url type="linkedin"}}" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
        {{> "icons/linkedin"}}
    </a>
    {{/if}}
    {{#if youtube}}
    <a class="gh-social-link" href="{{social_url type="youtube"}}" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
        {{> "icons/youtube"}}
    </a>
    {{/if}}
    {{#if threads}}
    <a class="gh-social-link" href="{{social_url type="threads"}}" target="_blank" rel="noopener noreferrer" aria-label="Threads">
        {{> "icons/threads"}}
    </a>
    {{/if}}
    {{#if bluesky}}
    <a class="gh-social-link" href="{{social_url type="bluesky"}}" target="_blank" rel="noopener noreferrer" aria-label="Bluesky">
        {{> "icons/bluesky"}}
    </a>
    {{/if}}
    {{#if mastodon}}
    <a class="gh-social-link" href="{{social_url type="mastodon"}}" target="_blank" rel="noopener noreferrer" aria-label="Mastodon">
        {{> "icons/mastodon"}}
    </a>
    {{/if}}
    {{#if tiktok}}
    <a class="gh-social-link" href="{{social_url type="tiktok"}}" target="_blank" rel="noopener noreferrer" aria-label="TikTok">
        {{> "icons/tiktok"}}
    </a>
    {{/if}}
    <a class="gh-social-link" href="{{@site.url}}/rss/" target="_blank" rel="noopener noreferrer" aria-label="RSS">
        {{> "icons/rss"}}
    </a>
</div>
{{/foreach}}
{{/get}}
